---
import { Picture } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { render } from "astro:content";
import { Icon } from "astro-icon/components";

import noImage from "@/assets/images/no-image.webp";
import ButtonLink from "@/components/ButtonLink.astro";
import Card from "@/components/Card.astro";
import Paragraph from "@/components/Paragraph.astro";

interface Props {
  entry: CollectionEntry<"publications">;
}

const { entry } = Astro.props;
const { data } = entry;

const { Content } = await render(entry);
const cover = data.cover || noImage;
---

<Card as="section" class="publication-card" noPadding>
  <div class="cover">
    <Picture
      src={cover}
      widths={[300, 600, 1200]}
      sizes={`(max-width: 600px) 600px, 300px`}
      formats={["avif", "webp"]}
      alt={data.title}
    />
  </div>
  <h3>{data.title}</h3>
  <Icon class="detail-icon date-icon" name="fluent:calendar-24-filled" />
  <time class="detail-text date">{data.date}</time>
  <main class="content">
    <Content
      components={{
        p: Paragraph,
      }}
    />
  </main>
  <footer>
    {
      data.links.map((link) => (
        <ButtonLink href={link.url} target="_blank" rel="noopener noreferrer">
          {link.label}
          <Icon name="fluent:open-16-filled" />
        </ButtonLink>
      ))
    }
  </footer>
</Card>

<style lang="scss">
  @use "@/assets/styles/variables" as var;

  .publication-card {
    height: 100%;
    display: grid;
    grid-template:
      "cover cover cover cover" auto
      "_l _gutter_1 _gutter_1 _r" 0.75rem
      "_l title title _r" auto
      "_l date-icon date _r" auto
      "_l content content _r" auto
      "_l _gutter_2 _gutter_2 _r" 0.25rem
      "_l footer footer _r" auto / 1rem auto 1fr 1rem;
    gap: 0.375rem 0.5rem;
    padding-bottom: 1.25rem;

    .cover {
      display: block;
      grid-area: cover;
      border-bottom: 1px solid var.$color-border;

      img {
        display: block;
        width: 100%;
        height: auto;
      }
    }

    .icon {
      grid-area: title-icon;
      width: 1.5rem;
      height: 1.5rem;
      color: var.$color-text-primary;
      place-self: center;
      transform: translateY(0.075rem);
    }

    h3 {
      grid-area: title;
      font-size: 1.25rem;
      color: var.$color-text-primary;
    }

    .date-icon {
      grid-area: date-icon;
    }

    .date {
      grid-area: date;
      display: block;
    }

    .detail-icon {
      width: 1rem;
      height: 1rem;
      color: var.$color-text-secondary;
      place-self: center;
    }

    .detail-text {
      font-size: 0.875rem;
      color: var.$color-text-secondary;
    }

    .content {
      grid-area: content;
    }

    footer {
      grid-area: footer;
      display: flex;
      flex-flow: row wrap;
      justify-content: center;
      gap: 0.5rem;
    }
  }
</style>
